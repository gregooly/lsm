@model LaundryMS.Web.Models.ViewModels.ReaderDetailViewModel
@{
    ViewData["Title"] = "Reader - " + Model.ReaderName;
}

<section class="page-header">
    <div>
        <h1 class="page-title">@Model.ReaderName</h1>
        <p class="page-subtitle">
            Reader profile and scan activity.
            @if (Model.IsActive)
            {
                <span class="badge bg-success ms-1">Active</span>
            }
            else
            {
                <span class="badge bg-secondary ms-1">Inactive</span>
            }
        </p>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Back to readers</a>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100"><div class="card-body py-3 text-center"><div class="small text-muted">Routes</div><div class="fs-4 fw-semibold">@Model.RouteCount</div></div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100"><div class="card-body py-3 text-center"><div class="small text-muted">Scans (24h)</div><div class="fs-4 fw-semibold">@Model.Scans24h</div></div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100"><div class="card-body py-3 text-center"><div class="small text-muted">Scans (7d)</div><div class="fs-4 fw-semibold">@Model.Scans7d</div></div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card section-card h-100"><div class="card-body py-3 text-center"><div class="small text-muted">Last seen</div><div class="small fw-semibold">@(Model.LastSeenAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</div></div></div>
    </div>
</div>

<div class="card section-card">
    <div class="card-header section-card-header">
        <h2 class="section-title mb-0"><i class="bi bi-cpu section-title-icon"></i>Reader profile</h2>
    </div>
    <div class="card-body">
        <dl class="row small mb-0">
            <dt class="col-sm-3 text-muted">Device identifier</dt>
            <dd class="col-sm-9"><code>@Model.DeviceIdentifier</code></dd>
            <dt class="col-sm-3 text-muted">Model</dt>
            <dd class="col-sm-9">@(Model.DeviceModel ?? "-")</dd>
            <dt class="col-sm-3 text-muted">Category</dt>
            <dd class="col-sm-9">@Model.ReaderCategory</dd>
            <dt class="col-sm-3 text-muted">Installed at</dt>
            <dd class="col-sm-9">@(Model.InstalledAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
            <dt class="col-sm-3 text-muted">Last heartbeat</dt>
            <dd class="col-sm-9">@(Model.LastHeartbeatAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
            <dt class="col-sm-3 text-muted">Maintenance note</dt>
            <dd class="col-sm-9">@(Model.MaintenanceNote ?? "-")</dd>
            <dt class="col-sm-3 text-muted">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
            <dt class="col-sm-3 text-muted">Updated</dt>
            <dd class="col-sm-9">@Model.UpdatedAt.ToString("u")</dd>
        </dl>
    </div>
</div>

<div class="card section-card mb-4">
    <div class="card-header section-card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
        <h2 class="section-title mb-0"><i class="bi bi-broadcast-pin section-title-icon"></i>URA8 / fixed reader MQTT</h2>
        <button type="button" class="btn btn-sm btn-primary" id="btnGenerateMqttCreds">Rotate MQTT password</button>
    </div>
    <div class="card-body">
        <p class="small text-muted mb-3">
            Configure the Chainway reader Web UI with these topics (QoS 1 recommended). EMQX must call
            <code>/api/mqtt/auth</code> and <code>/api/mqtt/acl</code> with header <code>X-LaundryMS-Mqtt-Webhook-Secret</code>.
            Enable <code>Mqtt:Enabled</code> on this server so LaundryMS subscribes to tag batches.
        </p>
        <dl class="row small mb-0">
            <dt class="col-sm-3 text-muted">MQTT username</dt>
            <dd class="col-sm-9"><code>@(Model.MqttUsername ?? "— not generated —")</code></dd>
            <dt class="col-sm-3 text-muted">Password</dt>
            <dd class="col-sm-9">@(Model.MqttPasswordConfigured ? "Configured (hidden)" : "Not set — click Rotate")</dd>
            <dt class="col-sm-3 text-muted">Broker status (LWT)</dt>
            <dd class="col-sm-9">
                @if (Model.MqttBrokerReportsOnline == true)
                {
                    <span class="badge bg-success">Online</span>
                }
                else if (Model.MqttBrokerReportsOnline == false)
                {
                    <span class="badge bg-secondary">Offline</span>
                }
                else
                {
                    <span class="badge bg-light text-dark border">Unknown</span>
                }
            </dd>
            <dt class="col-sm-3 text-muted">Tag batch topic</dt>
            <dd class="col-sm-9"><code class="small">@Model.ExampleTagTopic</code></dd>
            <dt class="col-sm-3 text-muted">Heartbeat topic</dt>
            <dd class="col-sm-9"><code class="small">@Model.ExampleHeartbeatTopic</code></dd>
            <dt class="col-sm-3 text-muted">Status (LWT) topic</dt>
            <dd class="col-sm-9"><code class="small">@Model.ExampleStatusTopic</code></dd>
            <dt class="col-sm-3 text-muted">Command subscribe</dt>
            <dd class="col-sm-9"><code class="small">@Model.ExampleCmdTopic</code></dd>
        </dl>
        <div id="mqttCredAlert" class="alert alert-warning mt-3 d-none small mb-0" role="alert"></div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        (() => {
            const btn = document.getElementById('btnGenerateMqttCreds');
            const alertEl = document.getElementById('mqttCredAlert');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            btn?.addEventListener('click', async () => {
                if (!confirm('Generate a new MQTT password? The reader must be updated with the new password immediately.')) return;
                const fd = new FormData();
                fd.append('__RequestVerificationToken', token);
                const url = '@Url.Action("GenerateMqttCredentials", "Readers", new { id = Model.Id })';
                const res = await fetch(url, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'fetch' } });
                const data = await res.json();
                if (!data?.ok) {
                    alertEl?.classList.remove('d-none');
                    if (alertEl) alertEl.textContent = data?.message ?? 'Failed to generate credentials.';
                    return;
                }
                const lines = [
                    data.reminder,
                    'Username: ' + data.mqttUsername,
                    'Password: ' + data.mqttPassword,
                    'Client ID: ' + data.clientId,
                    'Tags publish: ' + data.topicTags,
                    'Heartbeat publish: ' + data.topicHeartbeat,
                    'Status publish: ' + data.topicStatus,
                    'Subscribe commands: ' + data.topicCmd
                ];
                if (alertEl) {
                    alertEl.classList.remove('d-none');
                    alertEl.textContent = lines.join('\n');
                    alertEl.style.whiteSpace = 'pre-wrap';
                }
            });
        })();
    </script>
}
