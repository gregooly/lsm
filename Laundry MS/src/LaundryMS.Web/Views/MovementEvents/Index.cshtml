@model IReadOnlyList<LaundryMS.Web.Models.ViewModels.MovementEventListItemViewModel>

@{
    ViewData["Title"] = "Movement Events";
}

<section class="page-header">
    <div>
        <h1 class="page-title">Movement Events</h1>
        <p class="page-subtitle">Review applied, rejected, or duplicate RFID movement events.</p>
    </div>
    <div class="page-header-actions">
        <input type="text" class="form-control form-control-sm js-table-search" data-table-id="movementEventsTable" placeholder="Search movement events..." />
    </div>
</section>

<div class="card section-card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <p class="p-3 mb-0 text-muted">No movement events found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table id="movementEventsTable" class="table table-hover mb-0 js-filterable-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>RFID Tag</th>
                            <th>Reader</th>
                            <th>Way</th>
                            <th>Result</th>
                            <th>Occurred At</th>
                            <th>Received At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.RfidTag</td>
                                <td>@item.ReaderName</td>
                                <td>@item.WayName</td>
                                <td><span class="badge bg-dark text-uppercase">@item.ProcessingResult</span></td>
                                <td>@item.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@item.ReceivedAtServer.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
