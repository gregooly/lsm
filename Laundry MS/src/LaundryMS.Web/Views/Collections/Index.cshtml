<div class="modal fade" id="collectionDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="collectionDeleteForm" method="post" action="@Url.Action("Delete","Collections")">
                <input type="hidden" name="id" />
                <div class="modal-header">
                    <h5 class="modal-title">Delete job</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Are you sure you want to delete job <strong id="deleteJobId"></strong>?</p>
                    <p class="text-muted mb-0 mt-2">Deletion will be blocked if expected items are attached.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const antiforgery = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

            const toastEl = document.getElementById('collectionsToast');
            const toastBodyEl = document.getElementById('collectionsToastBody');
            const toast = toastEl ? new bootstrap.Toast(toastEl, { delay: 2500 }) : null;

            const createModalEl = document.getElementById('collectionCreateModal');
            const editModalEl = document.getElementById('collectionEditModal');
            const deleteModalEl = document.getElementById('collectionDeleteModal');
            const createModal = createModalEl ? new bootstrap.Modal(createModalEl) : null;
            const editModal = editModalEl ? new bootstrap.Modal(editModalEl) : null;
            const deleteModal = deleteModalEl ? new bootstrap.Modal(deleteModalEl) : null;

            const createForm = document.getElementById('collectionCreateForm');
            const editForm = document.getElementById('collectionEditForm');
            const deleteForm = document.getElementById('collectionDeleteForm');

            function showToast(message, isError) {
                if (!toastEl || !toastBodyEl || !toast) return;
                toastEl.classList.remove('text-bg-success', 'text-bg-danger');
                toastEl.classList.add(isError ? 'text-bg-danger' : 'text-bg-success');
                toastBodyEl.textContent = message;
                toast.show();
            }

            function clearValidation(form) {
                form.querySelectorAll('.is-invalid').forEach(x => x.classList.remove('is-invalid'));
                form.querySelectorAll('.invalid-feedback').forEach(x => x.textContent = '');
            }

            function applyErrors(form, errors) {
                if (!errors) return;
                Object.keys(errors).forEach(k => {
                    const msgs = errors[k] || [];
                    const field = form.querySelector(`[name="${k}"]`);
                    const feedback = form.querySelector(`.invalid-feedback[data-field="${k}"]`);
                    if (field) field.classList.add('is-invalid');
                    if (feedback) feedback.textContent = msgs[0] ?? 'Invalid value.';
                });
            }

            async function postForm(form) {
                const fd = new FormData(form);
                fd.append('__RequestVerificationToken', antiforgery);
                const res = await fetch(form.action, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'fetch' } });
                return await res.json();
            }

            function toDatetimeLocalValue(value) {
                if (!value) return '';
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return '';
                const pad = (n) => String(n).padStart(2, '0');
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            document.querySelector('.js-open-create')?.addEventListener('click', () => {
                if (!createModal || !createForm) return;
                createForm.reset();
                clearValidation(createForm);
                createModal.show();
            });

            document.querySelectorAll('.js-open-edit').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!editModal || !editForm) return;
                    clearValidation(editForm);
                    const id = btn.getAttribute('data-id');
                    const res = await fetch(`@Url.Action("Get","Collections")?id=${encodeURIComponent(id)}`, { headers: { 'X-Requested-With': 'fetch' } });
                    const data = await res.json();
                    if (!data?.ok) { showToast(data?.message ?? 'Failed to load job.', true); return; }

                    const j = data.job || {};
                    editForm.querySelector('[name="Id"]').value = j.id ?? j.Id ?? '';
                    editForm.querySelector('[name="JobType"]').value = (j.jobType ?? j.JobType ?? 'collection');
                    editForm.querySelector('[name="JobStatus"]').value = (j.jobStatus ?? j.JobStatus ?? 'open');
                    editForm.querySelector('[name="CustomerId"]').value = (j.customerId ?? j.CustomerId ?? '');
                    editForm.querySelector('[name="DriverId"]').value = (j.driverId ?? j.DriverId ?? '');
                    editForm.querySelector('[name="FromLocationId"]').value = String(j.fromLocationId ?? j.FromLocationId ?? '');
                    editForm.querySelector('[name="ToLocationId"]').value = String(j.toLocationId ?? j.ToLocationId ?? '');
                    editForm.querySelector('[name="ReaderWayId"]').value = String(j.readerWayId ?? j.ReaderWayId ?? '');
                    editForm.querySelector('[name="Notes"]').value = (j.notes ?? j.Notes ?? '');
                    editForm.querySelector('[name="PlannedStartAt"]').value = toDatetimeLocalValue(j.plannedStartAt ?? j.PlannedStartAt);
                    editForm.querySelector('[name="PlannedEndAt"]').value = toDatetimeLocalValue(j.plannedEndAt ?? j.PlannedEndAt);
                    editForm.querySelector('[name="ActualStartAt"]').value = toDatetimeLocalValue(j.actualStartAt ?? j.ActualStartAt);
                    editForm.querySelector('[name="ActualEndAt"]').value = toDatetimeLocalValue(j.actualEndAt ?? j.ActualEndAt);

                    editModal.show();
                });
            });

            document.querySelectorAll('.js-open-delete').forEach(btn => {
                btn.addEventListener('click', () => {
                    if (!deleteModal || !deleteForm) return;
                    const id = btn.getAttribute('data-id') ?? '';
                    deleteForm.querySelector('[name="id"]').value = id;
                    document.getElementById('deleteJobId').textContent = id;
                    deleteModal.show();
                });
            });

            createForm?.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearValidation(createForm);
                const data = await postForm(createForm);
                if (!data?.ok) {
                    applyErrors(createForm, data?.errors);
                    showToast(data?.message ?? 'Failed to create.', true);
                    return;
                }
                sessionStorage.setItem('collectionsToast', 'Created successfully.');
                window.location.reload();
            });

            editForm?.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearValidation(editForm);
                const data = await postForm(editForm);
                if (!data?.ok) {
                    applyErrors(editForm, data?.errors);
                    showToast(data?.message ?? 'Failed to save changes.', true);
                    return;
                }
                sessionStorage.setItem('collectionsToast', 'Updated successfully.');
                window.location.reload();
            });

            deleteForm?.addEventListener('submit', async (e) => {
                e.preventDefault();
                const data = await postForm(deleteForm);
                if (!data?.ok) { showToast(data?.message ?? 'Failed to delete.', true); return; }
                sessionStorage.setItem('collectionsToast', 'Deleted successfully.');
                window.location.reload();
            });

            const pendingToast = sessionStorage.getItem('collectionsToast');
            if (pendingToast) {
                sessionStorage.removeItem('collectionsToast');
                showToast(pendingToast, false);
            }
        })();
    </script>
}
