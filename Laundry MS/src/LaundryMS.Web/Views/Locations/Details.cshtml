@model LaundryMS.Web.Models.ViewModels.LocationDetailViewModel
@{
    ViewData["Title"] = "Location - " + Model.LocationName;
}

<section class="page-header">
    <div>
        <h1 class="page-title">@Model.LocationName</h1>
        <p class="page-subtitle">
            Location profile and network usage.
            @if (Model.IsActive)
            {
                <span class="badge bg-success ms-1">Active</span>
            }
            else
            {
                <span class="badge bg-secondary ms-1">Inactive</span>
            }
        </p>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Back to locations</a>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Linen here</div>
                <div class="fs-4 fw-semibold">@Model.LinkedLinenCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Scan routes</div>
                <div class="fs-4 fw-semibold">@Model.LinkedReaderWaysCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Open jobs</div>
                <div class="fs-4 fw-semibold">@Model.OpenLogisticsJobsCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card section-card h-100">
            <div class="card-header section-card-header">
                <h2 class="section-title mb-0"><i class="bi bi-geo section-title-icon"></i>Location data</h2>
            </div>
            <div class="card-body">
                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-muted">Type</dt>
                    <dd class="col-sm-8">@Model.LocationType</dd>
                    <dt class="col-sm-4 text-muted">Customer</dt>
                    <dd class="col-sm-8">@(Model.CustomerName ?? "-")</dd>
                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">@(Model.LocationAddressText ?? "-")</dd>
                    <dt class="col-sm-4 text-muted">Contact person</dt>
                    <dd class="col-sm-8">@(Model.ContactPerson ?? "-")</dd>
                    <dt class="col-sm-4 text-muted">Contact phone</dt>
                    <dd class="col-sm-8">@(Model.ContactPhone ?? "-")</dd>
                    <dt class="col-sm-4 text-muted">Coordinates</dt>
                    <dd class="col-sm-8">@(Model.GeoLat?.ToString("0.0000000") ?? "-"), @(Model.GeoLng?.ToString("0.0000000") ?? "-")</dd>
                    <dt class="col-sm-4 text-muted">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("u")</dd>
                    <dt class="col-sm-4 text-muted">Updated</dt>
                    <dd class="col-sm-8">@Model.UpdatedAt.ToString("u")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card section-card h-100">
            <div class="card-header section-card-header">
                <h2 class="section-title mb-0"><i class="bi bi-link-45deg section-title-icon"></i>Shortcuts</h2>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="ReaderWays" asp-action="Index">
                    <i class="bi bi-shuffle me-2"></i>Scan routes (filter by this location)
                </a>
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="LinenItems" asp-action="Index" asp-route-currentLocationId="@Model.Id">
                    <i class="bi bi-box-seam me-2"></i>Linen items currently here
                </a>
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="LogisticsJobs" asp-action="Index" asp-route-locationId="@Model.Id">
                    <i class="bi bi-truck me-2"></i>Logistics jobs touching this location
                </a>
            </div>
        </div>
    </div>
</div>
