@model LaundryMS.Web.Models.ViewModels.CustomerDetailViewModel
@{
    ViewData["Title"] = "Customer — " + Model.CustomerName;
}

<section class="page-header">
    <div>
        <h1 class="page-title">@Model.CustomerName</h1>
        <p class="page-subtitle">
            Account overview and quick links to linen, assignments, and logistics.
            <span class="text-muted">Type:</span> <strong>@Model.CustomerTypeDisplay</strong>
            @if (Model.IsActive)
            {
                <span class="badge bg-success ms-1">Active</span>
            }
            else
            {
                <span class="badge bg-secondary ms-1">Inactive</span>
            }
        </p>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Back to customers</a>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Employees</div>
                <div class="fs-4 fw-semibold">@Model.EmployeeCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Owned linen (active)</div>
                <div class="fs-4 fw-semibold">@Model.OwnedLinenActiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Owned linen (total)</div>
                <div class="fs-4 fw-semibold">@Model.OwnedLinenTotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Open jobs</div>
                <div class="fs-4 fw-semibold">@Model.OpenLogisticsJobsCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card section-card h-100">
            <div class="card-body py-3 text-center">
                <div class="small text-muted">Damaged linen</div>
                <div class="fs-4 fw-semibold text-danger">@Model.DamagedLinenCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card section-card h-100">
            <div class="card-header section-card-header">
                <h2 class="section-title mb-0"><i class="bi bi-person-lines-fill section-title-icon"></i>Contact</h2>
            </div>
            <div class="card-body">
                <dl class="row small mb-0">
                    <dt class="col-sm-3 text-muted">Email</dt>
                    <dd class="col-sm-9">@(Model.PrimaryEmail ?? "—")</dd>
                    <dt class="col-sm-3 text-muted">Phone</dt>
                    <dd class="col-sm-9">@(Model.PrimaryPhone ?? "—")</dd>
                    <dt class="col-sm-3 text-muted">Address</dt>
                    <dd class="col-sm-9">@(Model.AddressText ?? "—")</dd>
                    <dt class="col-sm-3 text-muted">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
                    <dt class="col-sm-3 text-muted">Updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("u")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card section-card h-100">
            <div class="card-header section-card-header">
                <h2 class="section-title mb-0"><i class="bi bi-link-45deg section-title-icon"></i>Shortcuts</h2>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="LinenItems" asp-action="Index" asp-route-customerId="@Model.Id">
                    <i class="bi bi-box-seam me-2"></i>Items owned by this customer
                </a>
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="LinenAssignment" asp-action="Index" asp-route-customerId="@Model.Id">
                    <i class="bi bi-people me-2"></i>Linen assignment (filtered)
                </a>
                <a class="btn btn-outline-primary btn-sm text-start" asp-controller="LogisticsJobs" asp-action="Index" asp-route-customerId="@Model.Id">
                    <i class="bi bi-truck me-2"></i>Logistics jobs
                </a>
            </div>
        </div>
    </div>
</div>

<p class="small text-muted mt-4 mb-0">
    <strong>Fixed</strong> vs <strong>Rental</strong> describes how this account typically uses linen; operators still set assignment per item under Linen assignment.
</p>
