<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gradient_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvLocationName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Hotel Sakura"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:padding="8dp"
            android:contentDescription="More" />
    </LinearLayout>

    <!-- Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_connected" />

        <TextView
            android:id="@+id/tvScanConnStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="@string/connected"
            android:textColor="@color/success"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_battery"
            android:contentDescription="Battery" />

        <TextView
            android:id="@+id/tvScanBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="—"
            android:textColor="@color/success"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Circular Counter (custom view placeholder shown as FrameLayout) -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center_horizontal">

            <!-- Outer glow background -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@drawable/bg_scan_glow"
                android:layout_gravity="center" />

            <!-- Custom CircularCounterView -->
            <com.example.driverapp.view.CircularCounterView
                android:id="@+id/circularCounter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/scanning_status"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/hold_trigger"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- STOP Button -->
            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_danger"
                android:drawableStart="@drawable/ic_stop"
                android:drawablePadding="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/btn_stop"
                android:textColor="@color/error"
                android:textSize="15sp"
                android:stateListAnimator="@null" />

            <!-- PAUSE Button -->
            <Button
                android:id="@+id/btnPause"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:drawableStart="@drawable/ic_pause"
                android:drawablePadding="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/btn_pause"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom CONFIRM PICKUP button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:padding="16dp">

        <Button
            android:id="@+id/btnConfirmPickup"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:fontFamily="sans-serif-medium"
            android:text="@string/btn_confirm_pickup"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:stateListAnimator="@null" />
    </LinearLayout>
</LinearLayout>
